# Anthropic API Key — starts with sk-ant-
# Found in: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GitHub Personal Access Token — needs 'repo' scope
# Create at: https://github.com/settings/tokens → Generate new token (classic) → check 'repo'
GITHUB_TOKEN=ghp-your-token-here

# GitHub Organization name — repos will be created here instead of your personal account
# Leave blank to create repos under your personal account
GITHUB_ORG=your-org-name-here

# Railway API Token — must be an account-level token (not a project token)
# Create at: https://railway.com/account/tokens
RAILWAY_TOKEN=your-railway-token-here

# GitHub token with delete_repo scope — used only by cleanup_deploy.py
# Create a separate token at: https://github.com/settings/tokens
GITHUB_TOKEN_CLEANUP=ghp-your-cleanup-token-here

# Persistent storage directory for sessions and solutions registry
# Local: set to the absolute path of your project root (e.g. /Users/you/demo-creation-agent)
# Railway: set to /data (Railway Volume mount point)
DATA_DIR=/absolute/path/to/demo-creation-agent

# Email notifications (optional) — used in auto mode to email when demo is done
# Create a free API key at: https://resend.com
RESEND_API_KEY=re_your-key-here

# --- Slack bot only (not needed for web UI) ---
# Slack Bot OAuth Token — starts with xoxb-
# Found in: Slack app dashboard → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack App-Level Token — starts with xapp-
# Found in: Slack app dashboard → Basic Information → App-Level Tokens
# Required scope: connections:write
SLACK_APP_TOKEN=xapp-your-token-here
